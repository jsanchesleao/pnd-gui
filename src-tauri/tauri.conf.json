{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pnd-gui",
  "version": "0.1.0",
  "identifier": "jsanchesleao.pnd-gui",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pnd-gui",
        "width": 400,
        "height": 300,
        "resizable": false,
        "maximizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
